# HTTP shim demo (`--features sia-live`).
# These endpoints must implement CoreSync's custom routes — NOT vanilla renterd/indexd.
# PUT/HEAD {SIA_API_ENDPOINT}/chunks/{hash}
# GET/PUT  {INDEXD_ENDPOINT}/manifests/{object_key}
SIA_API_ENDPOINT=http://localhost:9980
SIA_API_PASSWORD=your_shim_password
INDEXD_ENDPOINT=http://localhost:8080
INDEXD_API_KEY=your_shim_api_key

# Official Sia SDK path (`--features sia-sdk`). Requires a running indexd and an exported AppKey.
# SIA_INDEXER_URL=http://localhost:9982
# SIA_APP_KEY=your_exported_app_key
