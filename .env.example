# HTTP shim demo (`--features sia-live`).
# These endpoints must implement CoreSync's custom routes - NOT vanilla renterd/indexd.
SIA_API_ENDPOINT=
SIA_API_PASSWORD=
INDEXD_ENDPOINT=
INDEXD_API_KEY=

# Official Sia SDK path (`--features sia-sdk`).
# Requires a running indexd and an exported AppKey.
# IMPORTANT: use http://127.0.0.1:9982, NOT http://localhost:9982.
# indexd verifies request signatures against the IP it bound to; "localhost"
# causes a hash mismatch and an "invalid signature" error.
SIA_INDEXER_URL=
SIA_APP_KEY=

# Only needed for `cargo run --example register_app_key --features sia-sdk`.
SIA_RECOVERY_PHRASE=
