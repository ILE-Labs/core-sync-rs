# HTTP shim demo (`--features sia-live`).
# These endpoints must implement CoreSync's custom routes - NOT vanilla renterd/indexd.
SIA_API_ENDPOINT=
SIA_API_PASSWORD=
INDEXD_ENDPOINT=
INDEXD_API_KEY=

# Official Sia SDK path (`--features sia-sdk`).
# Requires a running indexd and an exported AppKey.
SIA_INDEXER_URL=
SIA_APP_KEY=

# Only needed for `cargo run --example register_app_key --features sia-sdk`.
SIA_RECOVERY_PHRASE=
